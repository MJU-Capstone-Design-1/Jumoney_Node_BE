# ────────────────────────────────────────────────────────────
# Jumoney 서버 환경변수 템플릿
# 사용법: 이 파일을 .env로 복사 후 실제 값으로 채워넣으세요.
#   cp .env.example .env
# ────────────────────────────────────────────────────────────

# ── 런타임 ─────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── 한국투자증권(KIS) 모의투자 ──────────────────────────────
KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
KIS_URL=https://openapivts.koreainvestment.com:29443
KIS_WS_URL=ws://ops.koreainvestment.com:31000

# ── Redis (docker-compose 내부 서비스명으로 해석됨) ────────
# 컨테이너 외부에서 직접 붙을 일이 없다면 호스트는 'redis' 그대로 둡니다.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_strong_password
